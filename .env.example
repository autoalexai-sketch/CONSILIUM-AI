APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# --- База данных ---
DATABASE_URL=sqlite:///./consilium.db

# --- Безопасность ---
# Генерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_generate_with_python

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- CORS ---
# Для разработки: *
# Для продакшена: https://your-domain.com
CORS_ORIGINS=*

# --- AI Провайдеры (минимум один обязателен) ---

# OpenRouter (рекомендуется — даёт доступ ко всем моделям)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (бесплатный, очень быстрый — для fast-track)
# Получить: https://console.groq.com
GROQ_API_KEY=

# DeepSeek V4 (приоритет 3 в fallback-цепочке — дёшево, MoE)
# Получить: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Amazon Bedrock (приоритет 2 в fallback-цепочке — оплачивается из AWS Activate credits)
# Создать IAM-ключ с политикой AmazonBedrockLimitedAccess в AWS Console -> IAM
# Модель должна быть включена в Bedrock Console -> Model access для выбранного региона
# Регион us-east-2 (Ohio) — там Llama 3.3 70B доступна напрямую (in-region),
# проверено в Bedrock Playground. В us-east-1 эта модель не работает напрямую.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
BEDROCK_MODEL_ID=meta.llama3-3-70b-instruct-v1:0

# Claude Haiku 4.5 через Bedrock — второй шанс для Synthesizer, когда у прямого
# ANTHROPIC_API_KEY кончился баланс. Другая авторизация, чем у Llama выше:
# не IAM access key, а отдельный Bedrock API key (bearer token).
# Создать: AWS Console -> Bedrock -> API keys -> Long-term keys -> Create key.
# Claude Sonnet 5 НЕ используется: на 07-2026 требует ручного запроса через
# AWS Sales, самостоятельно в консоли не включается. Haiku 4.5 in-region в
# us-east-1 напрямую (проверено по model card AWS docs), cross-region "us."
# префикс не нужен.
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_CLAUDE_REGION=us-east-1
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Anthropic Claude (для Synthesizer)
# Получить: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini
# Получить: https://aistudio.google.com
GEMINI_API_KEY=

# --- Ollama (опционально, только для локального запуска) ---
OLLAMA_URL=http://localhost:11434

# --- Email (опционально) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Stripe billing (опционально -- credit top-up) ---
# Без этих переменных биллинг-эндпоинты отвечают 503 "not configured",
# остальное приложение работает как обычно.
# 1. Тестовые ключи: https://dashboard.stripe.com/test/apikeys
# 2. STRIPE_WEBHOOK_SECRET: либо `stripe listen --forward-to localhost:8000/api/billing/webhook`
#    (печатает whsec_... в консоль), либо Dashboard > Developers > Webhooks > Add endpoint.
# 3. PUBLIC_BASE_URL должен совпадать с тем, откуда юзер реально открывает checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PUBLIC_BASE_URL=http://localhost:8000
