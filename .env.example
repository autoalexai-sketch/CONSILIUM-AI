APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# --- База данных ---
DATABASE_URL=sqlite:///./consilium.db

# --- Безопасность ---
# Генерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_generate_with_python

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- CORS ---
# Для разработки: *
# Для продакшена: https://your-domain.com
CORS_ORIGINS=*

# --- AI Провайдеры (минимум один обязателен) ---

# OpenRouter (рекомендуется — даёт доступ ко всем моделям)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (бесплатный, очень быстрый — для fast-track)
# Получить: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (для Synthesizer)
# Получить: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini
# Получить: https://aistudio.google.com
GEMINI_API_KEY=

# --- Ollama (опционально, только для локального запуска) ---
OLLAMA_URL=http://localhost:11434

# --- Email (опционально) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
