# ── Required ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
SECRET_KEY=change-me-to-random-32-chars-minimum

# ── Optional providers ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./consilium.db

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_EXPIRE_HOURS=24

# ── CORS (comma-separated, use * for dev) ─────────────────────────────────
CORS_ORIGINS=*

# ── SMTP (optional, for welcome emails) ───────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
